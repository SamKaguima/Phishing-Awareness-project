# Create a .env file based on this template and fill in the appropriate values for your environment.
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/phishing_awareness
IP_HASH_SALT=change-me-in-real-env
PG_SSL=false
INGESTION_AUDIT_ENABLED=true

# Public base URL for tracking links embedded in sent emails
APP_BASE_URL=http://localhost:3000

# Gmail SMTP credentials
# Use a Gmail App Password (NOT your real Google password):
# https://support.google.com/accounts/answer/185833
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
